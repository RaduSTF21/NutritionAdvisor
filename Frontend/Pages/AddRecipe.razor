@page "/add-recipe"
@using Frontend.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Add New Recipe</PageTitle>

<div class="container mt-4">
    <h1>👨‍🍳 Create a New Recipe</h1>
    <hr />

    <div class="row">
        <div class="col-md-7">
            <div class="card p-4 shadow-sm">
                <div class="mb-3">
                    <label class="form-label">Recipe Title</label>
                    <input @bind="newRecipe.Title" class="form-control" placeholder="Example: Parmesan Chicken" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea @bind="newRecipe.Description" class="form-control" rows="2"></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Cooking Time (min)</label>
                        <input type="number" @bind="newRecipe.CookingTimeInMinutes" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Difficulty</label>
                        <select @bind="newRecipe.Level" class="form-select">
                            <option value="Easy">Easy</option>
                            <option value="Medium">Medium</option>
                            <option value="Hard">Hard</option>
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Instructions</label>
                    <textarea @bind="newRecipe.Instructions" class="form-control" rows="4"></textarea>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card p-4 shadow-sm bg-light">
                <h5>🍎 Add Ingredients</h5>
                <div class="input-group mb-3">
                    <input @bind="searchTerm" @bind:event="oninput" @onkeyup="SearchIngredients" 
                           class="form-control" placeholder="Search ingredient (e.g. chicken)..." />
                </div>

                @if (foundIngredients.Any())
                {
                    <ul class="list-group mb-3">
                        @foreach (var ing in foundIngredients)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @ing.Name
                                <button class="btn btn-sm btn-primary" @onclick="() => AddToRecipe(ing)">+</button>
                            </li>
                        }
                    </ul>
                }

                <h6>Selected Ingredients:</h6>
                <ul class="list-group mb-3">
                    @foreach (var item in selectedIngredients)
                    {
                        <li class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <strong>@item.Name</strong>
                                <button class="btn btn-sm text-danger" @onclick="() => selectedIngredients.Remove(item)">x</button>
                            </div>
                            <div class="input-group input-group-sm mt-1">
                                <input type="number" @bind="item.Amount" class="form-control" placeholder="Amount" />
                                <span class="input-group-text">g</span>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="mt-4 mb-5">
        <button class="btn btn-lg btn-success w-100" @onclick="SaveRecipe" disabled="@(!selectedIngredients.Any())">
            💾 Save Recipe
        </button>
    </div>
</div>

@code {
    private RecipeCreateModel newRecipe = new();
    private string searchTerm = "";
    private List<IngredientSearchResult> foundIngredients = new();
    private List<SelectedIngredient> selectedIngredients = new();

    private async Task SearchIngredients()
    {
        if (searchTerm.Length > 1)
        {
            foundIngredients = await Http.GetFromJsonAsync<List<IngredientSearchResult>>($"api/Ingredients/search?searchTerm={searchTerm}") ?? new();
        }
        else { foundIngredients.Clear(); }
    }

    private void AddToRecipe(IngredientSearchResult ing)
    {
        if (!selectedIngredients.Any(i => i.Id == ing.Id))
        {
            selectedIngredients.Add(new SelectedIngredient { Id = ing.Id, Name = ing.Name, Amount = 100 });
        }
        searchTerm = "";
        foundIngredients.Clear();
    }

    private async Task SaveRecipe()
    {
        newRecipe.Ingredients = selectedIngredients.Select(i => new RecipeIngredientDto 
        { 
            IngredientId = i.Id, 
            Amount = i.Amount 
        }).ToList();

        var response = await Http.PostAsJsonAsync("api/Recipes", newRecipe);
        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/recipes");
        }
    }

    // Supporting classes for the form
    public class RecipeCreateModel {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public int CookingTimeInMinutes { get; set; } = 15;
        public string Level { get; set; } = "Easy";
        public string Instructions { get; set; } = "";
        public List<RecipeIngredientDto> Ingredients { get; set; } = new();
    }

    public class SelectedIngredient {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public float Amount { get; set; }
    }

    public class IngredientSearchResult {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
    }

    public class RecipeIngredientDto {
        public Guid IngredientId { get; set; }
        public float Amount { get; set; }
    }
}