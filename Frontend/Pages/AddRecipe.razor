@page "/add-recipe"
@using Frontend.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">👨‍🍳 Create Recipe</MudText>
    
    <MudGrid>
        <MudItem xs="12" md="7">
            <MudPaper Class="p-4" Elevation="2">
                <MudTextField Label="Title" @bind-Value="newRecipe.Title" Required="true" Placeholder="e.g. Grilled Chicken Salad" />
                <MudTextField Label="Description" @bind-Value="newRecipe.Description" Lines="2" />
                
                <div class="d-flex gap-4 mt-4">
                    <MudNumericField Label="Cooking Time (min)" @bind-Value="newRecipe.CookingTimeInMinutes" Min="1" />
                    <MudSelect Label="Difficulty" @bind-Value="newRecipe.Level">
                        <MudSelectItem Value="@("Easy")">Easy</MudSelectItem>
                        <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                        <MudSelectItem Value="@("Hard")">Hard</MudSelectItem>
                    </MudSelect>
                </div>

                <MudTextField Label="Instructions" @bind-Value="newRecipe.Instructions" Lines="5" Class="mt-4" Placeholder="Step by step instructions..." />
                <MudButton Variant="Variant.Filled" Color="Color.Success" Class="mt-6" FullWidth="true" 
                           OnClick="SaveRecipe" Disabled="@(!selectedIngredients.Any())">Save Recipe</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Class="p-4" Elevation="2" Style="background-color: #f9f9f9;">
                <MudText Typo="Typo.h6">🍎 Add Ingredients</MudText>
                <MudTextField T="string" Label="Search ingredient..." ValueChanged="OnSearch" 
                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search" />
                
                <MudList T="string">
                    @foreach (var ing in foundIngredients)
                    {
                        <MudListItem OnClick="() => AddIngredient(ing)">
                            <div class="d-flex justify-space-between">
                                <span>@ing.Name</span>
                                <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary" />
                            </div>
                        </MudListItem>
                    }
                </MudList>

                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle1">Selected Ingredients:</MudText>
                @if (!selectedIngredients.Any())
                {
                    <MudText Typo="Typo.body2" Class="text-muted italic">No ingredients added yet.</MudText>
                }
                @foreach (var item in selectedIngredients)
                {
                    <div class="d-flex align-center gap-2 mb-2">
                        <MudText Style="flex-grow: 1">@item.Name</MudText>
                        <MudNumericField @bind-Value="item.Amount" Label="Grams" Style="width: 80px;" Min="1" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="() => selectedIngredients.Remove(item)" />
                    </div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private RecipeCreateModel newRecipe = new();
    private List<IngredientSearchResult> foundIngredients = new();
    private List<SelectedIngredient> selectedIngredients = new();

    private async Task OnSearch(string text)
    {
        if (text?.Length > 1)
            foundIngredients = await Http.GetFromJsonAsync<List<IngredientSearchResult>>($"api/Ingredients/search?searchTerm={text}") ?? new();
        else
            foundIngredients.Clear();
    }

    private void AddIngredient(IngredientSearchResult ing)
    {
        if (!selectedIngredients.Any(i => i.Id == ing.Id))
            selectedIngredients.Add(new SelectedIngredient { Id = ing.Id, Name = ing.Name, Amount = 100 });
        foundIngredients.Clear();
    }

    private async Task SaveRecipe()
    {
        newRecipe.Ingredients = selectedIngredients.Select(i => new RecipeIngredientDto { IngredientId = i.Id, Amount = i.Amount }).ToList();
        var response = await Http.PostAsJsonAsync("api/Recipes", newRecipe);
        
        if (response.IsSuccessStatusCode) {
            Snackbar.Add("Recipe saved successfully!", Severity.Success);
            Navigation.NavigateTo("/recipes");
        }
    }

    public class RecipeCreateModel {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public int CookingTimeInMinutes { get; set; } = 20;
        public string Level { get; set; } = "Easy";
        public string Instructions { get; set; } = "";
        public List<RecipeIngredientDto> Ingredients { get; set; } = new();
    }
    public class SelectedIngredient { public Guid Id { get; set; } public string Name { get; set; } = ""; public float Amount { get; set; } }
    public class IngredientSearchResult { public Guid Id { get; set; } public string Name { get; set; } = ""; }
    public class RecipeIngredientDto { public Guid IngredientId { get; set; } public float Amount { get; set; } }
}