@page "/"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-16 text-center">
    <MudText Typo="Typo.h2" GutterBottom="true">Nutrition Advisor</MudText>
    <MudText Typo="Typo.h5" Class="mb-8">Your personal assistant for a healthy life.</MudText>

    <AuthorizeView>
        <Authorized>
            @* Authenticated user view *@
            <MudText Typo="Typo.h6" Class="mb-4">Welcome back, @context.User.Identity?.Name!</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" href="/profile">
                View Your Profile
            </MudButton>
        </Authorized>
        <NotAuthorized>
            @* Guest view *@
            <div class="d-flex justify-center gap-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" href="/login">
                    Login
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Large" href="/register">
                    Create Account
                </MudButton>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</MudContainer>