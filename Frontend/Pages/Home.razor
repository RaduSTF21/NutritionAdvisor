@page "/"

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-16">
    <MudGrid Justify="Justify.Center" AlignItems="AlignItems.Center">
        
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h2" Color="Color.Primary" GutterBottom="true"><b>Welcome to Nutrition Advisor!</b></MudText>
            <MudText Typo="Typo.h5" Class="mb-6">Achieve your health goals with AI-powered, personalized recipe recommendations tailored specifically to your body and dietary preferences.</MudText>
            
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mr-4" Href="/register">Create an Account</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" Href="/login">Login</MudButton>
        </MudItem>

        <MudItem xs="12" md="6">    
            <MudPaper Class="pa-6" Elevation="3">
                <MudText Typo="Typo.h6" Align="Align.Center" GutterBottom="true">Track Your Macros Easily</MudText>
                <MudChart ChartType="ChartType.Pie" InputData="@proc" InputLabels="@labels" />
            </MudPaper>
        </MudItem>

    </MudGrid>
</MudContainer>

@code{
    public double[] proc = new double[] { 50, 30, 20 };
    public string[] labels = new string[] { "Proteins", "Carbohydrates", "Fats" };
}