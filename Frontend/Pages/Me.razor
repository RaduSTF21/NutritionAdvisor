@page "/me"
@using MudBlazor
@using System.Net
@using System.Net.Http.Json
@using System.Security.Claims
@using NutritionAdvisor.Domain.Entities
@using NutritionAdvisor.Domain.Enums
@using Frontend.Models
@using Frontend.Auth
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Account & Personal</MudText>

    <MudExpansionPanels>
        <MudExpansionPanel Text="Profile">
            @if (editing)
            {
                <MudTextField Label="Name" @bind-Value="user.Name" />
                <MudSelect Label="Gender" @bind-Value="user.Gender">
                    <MudSelectItem Value="@("Male")">Male</MudSelectItem>
                    <MudSelectItem Value="@("Female")">Female</MudSelectItem>
                    <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                </MudSelect>
                <MudSelect Label="Objective" @bind-Value="user.Objective">
                    <MudSelectItem Value="@("Weight Loss")">Weight Loss</MudSelectItem>
                    <MudSelectItem Value="@("Maintain")">Maintain</MudSelectItem>
                    <MudSelectItem Value="@("Muscle Gain")">Muscle Gain</MudSelectItem>
                </MudSelect>
                <MudNumericField Label="Age" @bind-Value="user.Age" />
                <MudNumericField Label="Weight (kg)" @bind-Value="user.Weight" />
                <MudNumericField Label="Height (cm)" @bind-Value="user.Height" />
                <MudTextField Label="Allergies" @bind-Value="user.Allergies" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveProfile">Save</MudButton>
            }
            else
            {
                <MudText Typo="Typo.h6">Name: <b>@user.Name</b></MudText>
                <MudText Typo="Typo.body2">Gender: @user.Gender</MudText>
                <MudText Typo="Typo.body2">Objective: @user.Objective</MudText>
                <MudText Typo="Typo.body2">Age: @user.Age</MudText>
                <MudText Typo="Typo.body2">Weight: @user.Weight kg</MudText>
                <MudText Typo="Typo.body2">Height: @user.Height cm</MudText>
                <MudText Typo="Typo.body2">Allergies: @user.Allergies</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="() => editing = true">Edit
                </MudButton>
            }
        </MudExpansionPanel>

        <MudExpansionPanel Text="Allergies">
            <MudPaper Class="pa-4 mb-4">
                <MudTextField Label="Allergen name" @bind-Value="newAllergy.AllergenName" Class="mb-3" />

                <MudSelect T="AllergySeverity" Label="Severity" @bind-Value="newAllergy.SeverityLevel" Class="mb-4">
                    @foreach (var severity in Enum.GetValues<AllergySeverity>())
                    {
                        <MudSelectItem T="AllergySeverity" Value="@severity">@severity</MudSelectItem>
                    }
                </MudSelect>

                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AddAllergy">Add Allergy</MudButton>
            </MudPaper>

            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Saved Allergies</MudText>
                @if (!allergies.Any())
                {
                    <MudText>No allergies added yet.</MudText>
                }
                else
                {
                    @foreach (var allergy in allergies)
                    {
                        <div class="d-flex align-center mb-2">
                            <MudText>@allergy.AllergenName (@allergy.SeverityLevel)</MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           OnClick="@(() => DeleteAllergy(allergy.Id))" />
                        </div>
                    }
                }
            </MudPaper>
        </MudExpansionPanel>

        <MudExpansionPanel Text="Food Preferences">
            <MudPaper Class="pa-4">
                <MudSelect T="DietType" Label="Diet type" @bind-Value="prefModel.DietType" Class="mb-4">
                    @foreach (var dietType in Enum.GetValues<DietType>())
                    {
                        <MudSelectItem T="DietType" Value="@dietType">@dietType</MudSelectItem>
                    }
                </MudSelect>

                <MudTextField Label="Preferred cuisines (comma separated)" @bind-Value="preferredCuisinesText"
                              Class="mb-3" />

                <MudTextField Label="Disliked ingredients (comma separated)" @bind-Value="dislikedIngredientsText"
                              Class="mb-4" />

                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SavePreferences">Save Preferences
                </MudButton>
            </MudPaper>
        </MudExpansionPanel>

        <MudExpansionPanel Text="Overview">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudPaper Class="p-4 rounded-lg shadow-sm" Elevation="2">
                        <MudText Typo="Typo.h6">Body Stats</MudText>
                        @if (userProfile == null)
                        {
                            <MudText>No profile data found.</MudText>
                        }
                        else
                        {
                            <div class="d-flex justify-space-between mb-2">
                                <MudText>Weight:</MudText>
                                <MudText><b>@userProfile.Weight kg</b></MudText>
                            </div>
                            <MudText>Goal: <b>@(userProfile.Objective ?? "Not set")</b></MudText>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudPaper Class="p-4 rounded-lg shadow-sm" Elevation="2">
                        <MudText Typo="Typo.h6">Recipe Library</MudText>
                        <div class="text-center py-4">
                            <MudText Typo="Typo.h3" Color="Color.Primary">@recipeCount</MudText>
                            <MudText Typo="Typo.body1">Available Recipes</MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-4" Href="/recipes">
                                Browse Recipes
                            </MudButton>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudExpansionPanel>
    </MudExpansionPanels>
</MudContainer>

@code {
    // Profile
    private bool editing = false;
    private UserProfile user = new()
    {
        UserId = Guid.Empty,
        Name = "",
        Gender = "",
        Objective = "",
        Allergies = ""
    };

    // Allergies
    private readonly List<AllergyVm> allergies = new();
    private AllergyVm newAllergy = new() { SeverityLevel = AllergySeverity.Mild };

    // Preferences
    private FoodPreferenceVm prefModel = new();
    private string preferredCuisinesText = string.Empty;
    private string dislikedIngredientsText = string.Empty;

    // Overview
    private UserProfile? userProfile;
    private int recipeCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfile();
        await LoadAllergies();
        await LoadPreferences();
        await LoadRecipeCount();
    }

    private async Task LoadProfile()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userClaim = authState.User;
        if (userClaim.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = userClaim.FindFirst(ClaimTypes.NameIdentifier);
            if (userIdClaim != null && Guid.TryParse(userIdClaim.Value, out var userId))
            {
                try
                {
                    var response = await Http.GetAsync($"api/UserProfile/{userId}");
                    if (response.StatusCode == HttpStatusCode.Unauthorized || response.StatusCode == HttpStatusCode.Forbidden)
                    {
                        await HandleAuthorizationFailure();
                        return;
                    }

                    if (response.IsSuccessStatusCode)
                    {
                        var existing = await response.Content.ReadFromJsonAsync<UserProfile>();
                        if (existing != null)
                        {
                            user = existing;
                            userProfile = existing;
                        }
                        else
                        {
                            editing = true;
                        }
                    }
                    else
                    {
                        editing = true;
                    }
                }
                catch
                {
                    editing = true;
                }
            }
        }
    }

    private async Task SaveProfile()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userClaim = authState.User;
        var userIdClaim = userClaim.FindFirst(ClaimTypes.NameIdentifier);
        if (userIdClaim != null && Guid.TryParse(userIdClaim.Value, out var userId))
        {
            user.UserId = userId;
            var response = await Http.PostAsJsonAsync("api/userprofile", user);
            if (response.StatusCode == HttpStatusCode.Unauthorized || response.StatusCode == HttpStatusCode.Forbidden)
            {
                await HandleAuthorizationFailure();
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                editing = false;
                Snackbar.Add("Profile saved successfully.", Severity.Success);
                await LoadProfile();
                return;
            }

            Snackbar.Add("Profile could not be saved.", Severity.Error);
        }
    }

    private async Task LoadAllergies()
    {
        try
        {
            var response = await Http.GetAsync("api/Allergies");
            if (response.StatusCode == HttpStatusCode.Unauthorized || response.StatusCode == HttpStatusCode.Forbidden)
            {
                await HandleAuthorizationFailure();
                return;
            }

            allergies.Clear();
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<List<AllergyVm>>();
                if (result != null) allergies.AddRange(result);
            }
        }
        catch { Snackbar.Add("Could not load allergies.", Severity.Error); }
    }

    private async Task AddAllergy()
    {
        if (string.IsNullOrWhiteSpace(newAllergy.AllergenName))
        {
            Snackbar.Add("Allergen name is required.", Severity.Warning);
            return;
        }

        var response = await Http.PostAsJsonAsync("api/Allergies", newAllergy);
        if (response.StatusCode == HttpStatusCode.Unauthorized || response.StatusCode == HttpStatusCode.Forbidden)
        {
            await
HandleAuthorizationFailure(); return;
        }

        if (response.IsSuccessStatusCode)
        {
            newAllergy = new AllergyVm { SeverityLevel = AllergySeverity.Mild };
            await LoadAllergies();
            Snackbar.Add("Allergy added.", Severity.Success);
        }
        else Snackbar.Add("Could not add allergy.", Severity.Error);
    }

    private async Task DeleteAllergy(Guid id)
    {
        var response = await Http.DeleteAsync($"api/Allergies/{id}");
        if (response.StatusCode == HttpStatusCode.Unauthorized || response.StatusCode == HttpStatusCode.Forbidden)
        {
            await
HandleAuthorizationFailure(); return;
        }

        if (response.IsSuccessStatusCode)
        {
            allergies.RemoveAll(a => a.Id == id);
            Snackbar.Add("Allergy removed.", Severity.Success);
        }
        else Snackbar.Add("Could not remove allergy.", Severity.Error);
    }

    private async Task LoadPreferences()
    {
        try
        {
            var response = await Http.GetAsync("api/FoodPreferences");
            if (response.StatusCode == HttpStatusCode.Unauthorized || response.StatusCode == HttpStatusCode.Forbidden)
            {
                await
HandleAuthorizationFailure(); return;
            }

            if (response.IsSuccessStatusCode)
            {
                var existing = await response.Content.ReadFromJsonAsync<FoodPreferenceVm>();
                if (existing != null)
                {
                    prefModel = existing;
                    preferredCuisinesText = string.Join(", ", prefModel.PreferredCuisines);
                    dislikedIngredientsText = string.Join(", ", prefModel.DislikedIngredients);
                }
            }
        }
        catch { Snackbar.Add("Could not load food preferences.", Severity.Warning); }
    }

    private async Task SavePreferences()
    {
        prefModel.PreferredCuisines = ParseCsv(preferredCuisinesText);
        prefModel.DislikedIngredients = ParseCsv(dislikedIngredientsText);

        var response = await Http.PostAsJsonAsync("api/FoodPreferences", prefModel);
        if (response.StatusCode == HttpStatusCode.Unauthorized || response.StatusCode == HttpStatusCode.Forbidden)
        {
            await
HandleAuthorizationFailure(); return;
        }

        if (response.IsSuccessStatusCode) Snackbar.Add("Preferences saved.", Severity.Success); else Snackbar.Add("Could not save preferences.", Severity.Error);
    }

    private List<string> ParseCsv(string input) => input.Split(',', StringSplitOptions.TrimEntries |
StringSplitOptions.RemoveEmptyEntries).ToList();

    private async Task LoadRecipeCount()
    {
        try { var recipes = await Http.GetFromJsonAsync<List<RecipeModel>>("api/Recipes"); recipeCount = recipes?.Count ?? 0; }
        catch { /* ignore */ }
    }

    private async Task HandleAuthorizationFailure()
    {
        if (AuthStateProvider is CustomAuthStateProvider customAuth) await customAuth.MarkUserAsLoggedOut();
        Snackbar.Add("Session expired or invalid. Please log in again.", Severity.Warning);
        Navigation.NavigateTo("/login");
    }

    // Small view models
    private class AllergyVm
    {
        public Guid Id { get; set; }
        public string AllergenName { get; set; } = string.Empty; public
AllergySeverity SeverityLevel
        { get; set; }
    }
    private class FoodPreferenceVm
    {
        public DietType DietType { get; set; } = DietType.None; public List<string>
PreferredCuisines
        { get; set; } = new(); public List<string> DislikedIngredients { get; set; } = new();
    }
}
