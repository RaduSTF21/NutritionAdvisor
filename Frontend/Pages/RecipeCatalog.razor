@page "/recipes"
@using Frontend.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h4">Recipe Catalog</MudText>
        <AuthorizeView>
            <Authorized>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           href="/add-recipe">
                    New Recipe
                </MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Login"
                           OnClick="@(() => Navigation.NavigateTo("/login"))">
                    Log in to add recipes
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    @if (recipes == null)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (!recipes.Any())
    {
        <MudAlert Severity="Severity.Info">No recipes found. Be the first to add one!</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var recipe in recipes)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="3" Class="rounded-lg h-100">
                        <MudCardMedia Image="@BuildImageUrl(recipe.ImageURL)" Height="200" />
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@recipe.Title</MudText>
                            <MudText Typo="Typo.body2" Class="text-muted mb-2">⏱ @recipe.CookingTimeInMinutes min |
                                @recipe.Level</MudText>
                            
                                <MudDivider Class="my-2" />
                            
                                <div class="d-flex justify-space-around py-2 bg-light rounded">
                                    <div class="text-center">
                                        <MudText Typo="Typo.subtitle2"><b>@recipe.TotalCalories.ToString("F0")</b></MudText>
                                        <MudText Typo="Typo.caption">kcal</MudText>
                                    </div>
                                    <div class="text-center">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                                            <b>@recipe.TotalProtein.ToString("F1")g</b>
                                        </MudText>
                                        <MudText Typo="Typo.caption">P</MudText>
                                    </div>
                                    <div class="text-center">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Success">
                                            <b>@recipe.TotalCarbs.ToString("F1")g</b>
                                        </MudText>
                                        <MudText Typo="Typo.caption">C</MudText>
                                    </div>
                                </div>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true"
                                           href="@($"/recipe/{recipe.Id}")">View Details</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudContainer>

@code {
    private List<RecipeModel>? recipes;
    private string ApiBaseUrl = "http://localhost:5066";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            recipes = await Http.GetFromJsonAsync<List<RecipeModel>>("api/Recipes");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading recipes: {ex.Message}");
        }
    }

    private string BuildImageUrl(string? url)
    {
        if (string.IsNullOrEmpty(url))
            return "https://via.placeholder.com/300x200?text=No+Image";

        if (url.StartsWith("http"))
            return url;

        return $"{ApiBaseUrl}{url}";
    }
}