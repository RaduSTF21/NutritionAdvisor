@page "/retete"
@using NutritionAdvisor.Domain.Entities
@using MudBlazor
@using MudText = MudBlazor.MudText

<MudText Typo = "Typo.h3" GutterBottom="true">AI Personalized Recipes</MudText>
<MudGrid>
@foreach (var reteta in retete)
    {
        <MudItem xs="12" sm="6" md="4">
        <MudCard Class = "mb-4">
            <MudCardMedia Image="@reteta.ImageURL" Height="200" />
            <MudCardContent>
                <MudText Typo="Typo.h5">@reteta.Title</MudText>
                <MudText>Calories: @reteta.Calories</MudText>
                <MudText>Cooking time: @reteta.CookingTime minutes</MudText>
            </MudCardContent>
        </MudCard>
        </MudItem>
        }
</MudGrid>
@code
{
    private List<Reteta> retete = new List<Reteta>
        {
            new Reteta {Id = Guid.NewGuid(), Title = "Chicken with rice and broccoli",  Calories = 450, CookingTime = 25, ImageURL= "https://images.unsplash.com/photo-1467003909585-2f8a72700288?w=300"},
            new Reteta { Id = Guid.NewGuid(), Title = "Salmon in oven with asparagus", Calories = 520, CookingTime = 30, ImageURL = "https://images.unsplash.com/photo-1512621776951-a57141f2eefd?w=300" },
            new Reteta { Id = Guid.NewGuid(), Title = "Protein smoothie with spinach", Calories = 250, CookingTime = 5, ImageURL = "https://images.unsplash.com/photo-1553530666-ba11a7da3888?w=300" }
        };
        
    
}
