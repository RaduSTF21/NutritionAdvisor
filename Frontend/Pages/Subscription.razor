@page "/subscription"
@using Frontend.Auth
@using Frontend.Models
@using System.Net
@using System.Net.Http.Json
@using System.Security.Claims
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Class="pa-6 subscription-hero" Elevation="3">
        <MudText Typo="Typo.h4" Class="mb-2">Subscription</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">Check your current plan and jump to the AI features available for your account.</MudText>

        @if (subscription == null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudCard Elevation="2" Class="pa-4 h-100">
                        <MudText Typo="Typo.h6">Current plan</MudText>
                        <MudText Typo="Typo.h4" Color="@(IsPremium ? Color.Success : Color.Info)">@subscription.Plan</MudText>
                        <MudChip T="string" Color="@(IsPremium ? Color.Success : Color.Default)" Class="mt-2">@subscription.Status</MudChip>
                        <MudText Class="mt-4">Expires: @(subscription.ExpiresAt?.ToString("yyyy-MM-dd HH:mm") ?? "No expiration set")</MudText>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudCard Elevation="2" Class="pa-4 h-100">
                        <MudText Typo="Typo.h6">Available actions</MudText>
                        <MudStack Spacing="2" Class="mt-3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/ai">
                                Open AI hub
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/recipes">
                                Browse recipes
                            </MudButton>
                        </MudStack>
                    </MudCard>
                </MudItem>
            </MudGrid>
        }
    </MudPaper>
</MudContainer>

@code {
    private SubscriptionModel? subscription;

    private bool IsPremium => subscription != null
        && string.Equals(subscription.Plan, "Premium", StringComparison.OrdinalIgnoreCase)
        && string.Equals(subscription.Status, "Active", StringComparison.OrdinalIgnoreCase)
        && subscription.ExpiresAt > DateTime.UtcNow;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var response = await Http.GetAsync("api/subscription/me");
        if (response.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            if (AuthStateProvider is CustomAuthStateProvider customAuth)
            {
                await customAuth.MarkUserAsLoggedOut();
            }

            Navigation.NavigateTo("/login");
            return;
        }

        if (response.IsSuccessStatusCode)
        {
            subscription = await response.Content.ReadFromJsonAsync<SubscriptionModel>();
        }
    }
}
